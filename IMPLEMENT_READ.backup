## 26.4 `apps/api/src/lib/rag/citation-normalizer.ts`

```ts
import crypto from "crypto";
import type { RetrievedChunk } from "./rag-adapter.interface";
import type { AISource } from "@fitversum/contracts";

export function normalizeChunksToSources(chunks: RetrievedChunk[]): AISource[] {
  return chunks.map((c) => ({
    documentId: c.documentId,
    title: c.title,
    author: c.author,
    year: c.year,
    pageStart: c.pageStart,
    pageEnd: c.pageEnd,
    chunkId: c.chunkId,
    score: c.score,
    locator: c.locator
  }));
}

export function makeCitationId(chunk: Pick<RetrievedChunk, "documentId" | "chunkId">) {
  return `cit_${crypto.createHash("sha1").update(`${chunk.documentId}:${chunk.chunkId}`).digest("hex").slice(0, 10)}`;
}

export function buildShortQuote(text: string, maxLen = 180) {
  const clean = text.replace(/\s+/g, " ").trim();
  return clean.length <= maxLen ? clean : `${clean.slice(0, maxLen - 1)}…`;
}
```

## 26.5 `apps/api/src/lib/rag/rag.service.ts`

```ts
import { Injectable } from "@nestjs/common";
import type { AIChatResponse } from "@fitversum/contracts";
import type { RagAdapter } from "./rag-adapter.interface";
import { normalizeChunksToSources, makeCitationId, buildShortQuote } from "./citation-normalizer";

@Injectable()
export class RagService {
  private minScore = Number(process.env.RAG_MIN_SCORE ?? 0.72);
  private minDocs = Number(process.env.RAG_MIN_DOCS ?? 1);
  private minHits = Number(process.env.RAG_MIN_HITS ?? 2);

  constructor(private readonly ragAdapter: RagAdapter) {}

  async answerWithCitations(
    message: string,
    locale: string,
    includeProductSuggestion = true
  ): Promise<AIChatResponse> {
    const retrieved = await this.ragAdapter.retrieve({
      query: message,
      topK: Number(process.env.RAG_TOPK ?? 6),
      minScore: this.minScore
    });

    const uniqueDocs = new Set(retrieved.map((r) => r.documentId)).size;
    const gateOk = retrieved.length >= this.minHits && uniqueDocs >= this.minDocs;

    if (!gateOk) {
      return {
        answer: locale.startsWith("pt")
          ? "Não encontrei base suficiente nas fontes aprovadas para responder com segurança. Posso refinar a busca ou sugerir leitura."
          : "Insufficient approved-source basis to answer safely.",
        sources: [],
        safety: { ragUsed: true, blocked: true, reason: "rag_gate_failed" },
        ...(includeProductSuggestion ? {
          productSuggestion: { productId: "fitversum-box", why: "Leitura complementar relacionada ao tema consultado." }
        } : {})
      };
    }

    const sources = normalizeChunksToSources(retrieved);

    return {
      answer: locale.startsWith("pt")
        ? "Resposta baseada em fontes aprovadas (RAG governado). Considere objetivo, volume, recuperação e supervisão técnica ao aplicar a prescrição."
        : "Answer based on approved sources (governed RAG).",
      sources,
      safety: { ragUsed: true, blocked: false },
      ...(includeProductSuggestion ? {
        productSuggestion: { productId: "my-fit-box", why: "Conteúdo complementar sobre o tema pesquisado." }
      } : {})
    };
  }

  buildScannerEvidencePlaceholders() {
    return [
      {
        citationId: makeCitationId({ documentId: "doc_scanner_1", chunkId: "chunk_eq_1" }),
        title: "Fonte aprovada (scanner)",
        locator: "p.45-47",
        quote: buildShortQuote("Trecho governado sobre execução e músculos envolvidos no equipamento identificado.")
      }
    ];
  }
}
```

