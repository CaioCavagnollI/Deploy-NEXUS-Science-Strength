# 27) AI MODULE / CONTROLLER (V5)

## 27.1 `apps/api/src/modules/ai/ai.controller.ts`

```ts
import { BadRequestException, Body, Controller, Get, Post, UseGuards } from "@nestjs/common";
import { z } from "zod";
import { RagService } from "../../lib/rag/rag.service";
import { AuthGuard } from "../../common/guards/auth.guard";
import { PlansGuard } from "../../common/guards/plans.guard";
import { Plans } from "../../common/decorators/plans.decorator";
import { CurrentUser } from "../../common/decorators/current-user.decorator";
import type { AuthUserContext } from "@fitversum/contracts";
import { UsageService } from "../../lib/usage/usage.service";

const chatWithSourcesSchema = z.object({
  message: z.string().min(2),
  locale: z.string().default("pt-BR"),
  includeProductSuggestion: z.boolean().optional().default(true)
});

@Controller("ai")
export class AiController {
  constructor(
    private readonly ragService: RagService,
    private readonly usageService: UsageService
  ) {}

  @Post("chat-with-scientific-sources")
  @UseGuards(AuthGuard, PlansGuard)
  @Plans("free", "pro", "pro_plus", "b2b", "university")
  async chat(@Body() body: unknown, @CurrentUser() user: AuthUserContext) {
    const parsed = chatWithSourcesSchema.safeParse(body);
    if (!parsed.success) throw new BadRequestException(parsed.error.flatten());

    await this.usageService.assertAndIncrement(user, "ai_messages_count", 1);

    return this.ragService.answerWithCitations(
      parsed.data.message,
      parsed.data.locale,
      parsed.data.includeProductSuggestion
    );
  }

  @Get("usage/me")
  @UseGuards(AuthGuard)
  async getMyUsage(@CurrentUser() user: AuthUserContext) {
    return this.usageService.getCurrentUsage(user);
  }
}
```

