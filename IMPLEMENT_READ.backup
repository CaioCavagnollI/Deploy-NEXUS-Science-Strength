# 10) CONTRATOS TYPECRIPT (CORE)

## 10.1 Roles, Plans, User Context

```ts
export type Role =
  | "visitor"
  | "student"
  | "subscriber"
  | "professional"
  | "company"
  | "affiliate"
  | "admin";

export type PlanTier =
  | "free"
  | "pro"
  | "pro_plus"
  | "university"
  | "b2b";

export interface AuthUserContext {
  userId: string;
  role: Role;
  planTier: PlanTier;
  institutionId?: string | null;
  isFounder?: boolean;
}
```

## 10.2 Chat / AI response

```ts
export interface AISource {
  documentId: string;
  title: string;
  author?: string;
  year?: number;
  pageStart?: number;
  pageEnd?: number;
  chunkId: string;
  score: number;
  locator?: string;
}

export interface AIChatResponse {
  answer: string;
  sources: AISource[];
  safety: {
    ragUsed: boolean;
    blocked: boolean;
    reason?: string;
  };
  productSuggestion?: {
    productId: string;
    why: string;
  };
}
```

## 10.3 Scanner contracts

```ts
export interface ScannerRequest {
  assetId: string;
  goal?: string;
  constraints?: string[];
  level?: "beginner" | "intermediate" | "advanced";
  userSelected?: {
    equipId?: string;
    exerciseFamily?: string;
  };
}

export type ScannerStatus = "OK" | "FALLBACK";

export interface ScannerCitation {
  citationId: string;
  title: string;
  locator?: string;
  quote?: string;
}

export interface ScannerResponse {
  status: ScannerStatus;
  equipmentName?: string;
  equipId?: string;
  compatibleExercises?: string[];
  muscles?: {
    primeMovers: string[];
    synergists: string[];
    stabilizers: string[];
  };
  evidence?: {
    citations: ScannerCitation[];
    snippets?: string[];
  };
  assumptions?: string[];
  confidenceScore?: number;
  scanId: string;
  message?: string; // fallback message
}
```

## 10.4 RAG Abstraction

```ts
export interface RetrievedChunk {
  chunkId: string;
  documentId: string;
  title: string;
  author?: string;
  year?: number;
  score: number;
  content: string;
  locator?: string;
  pageStart?: number;
  pageEnd?: number;
}

export interface RagRetrieveParams {
  query: string;
  topK?: number;
  minScore?: number;
  filters?: Record<string, unknown>;
}

export interface RagAdapter {
  retrieve(params: RagRetrieveParams): Promise<RetrievedChunk[]>;
}

export interface AIProvider {
  embed(text: string): Promise<number[]>;
  generate(input: {
    prompt: string;
    context: { content: string; meta: Record<string, any> }[];
  }): Promise<{ text: string }>;
}
```

