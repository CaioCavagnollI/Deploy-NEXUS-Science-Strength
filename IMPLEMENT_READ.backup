# 22) NESTJS — GUARDS / DECORATORS (AUTH / ROLES / PLANS)

## 22.1 `CurrentUser` decorator

```ts
import { createParamDecorator, ExecutionContext } from "@nestjs/common";
import type { AuthUserContext } from "@fitversum/contracts";

export const CurrentUser = createParamDecorator(
  (_: unknown, ctx: ExecutionContext): AuthUserContext => {
    const req = ctx.switchToHttp().getRequest();
    return req.user;
  }
);
```

## 22.2 `Roles` / `Plans` decorators

```ts
import { SetMetadata } from "@nestjs/common";

export const ROLES_KEY = "roles";
export const Roles = (...roles: string[]) => SetMetadata(ROLES_KEY, roles);

export const PLANS_KEY = "plans";
export const Plans = (...plans: string[]) => SetMetadata(PLANS_KEY, plans);
```

## 22.3 `AuthGuard` (stub com Supabase JWT)

```ts
import { CanActivate, ExecutionContext, Injectable, UnauthorizedException } from "@nestjs/common";
import { getSupabaseAdmin } from "../../lib/supabase/supabase-admin";

@Injectable()
export class AuthGuard implements CanActivate {
  async canActivate(ctx: ExecutionContext): Promise<boolean> {
    const req = ctx.switchToHttp().getRequest();
    const authHeader = req.headers.authorization as string | undefined;

    if (!authHeader?.startsWith("Bearer ")) throw new UnauthorizedException("Missing bearer token");
    const token = authHeader.slice("Bearer ".length);

    const supabase = getSupabaseAdmin();
    const { data, error } = await supabase.auth.getUser(token);
    if (error || !data.user) throw new UnauthorizedException("Invalid token");

    const { data: profile } = await supabase
      .from("profiles")
      .select("role, plan_tier, institution_id, is_founder")
      .eq("user_id", data.user.id)
      .single();

    req.user = {
      userId: data.user.id,
      role: profile?.role ?? "student",
      planTier: profile?.plan_tier ?? "free",
      institutionId: profile?.institution_id ?? null,
      isFounder: profile?.is_founder ?? false
    };

    return true;
  }
}
```

## 22.4 `RolesGuard` / `PlansGuard`

```ts
import { CanActivate, ExecutionContext, ForbiddenException, Injectable } from "@nestjs/common";
import { Reflector } from "@nestjs/core";
import { ROLES_KEY } from "../decorators/roles.decorator";
import { PLANS_KEY } from "../decorators/plans.decorator";

@Injectable()
export class RolesGuard implements CanActivate {
  constructor(private reflector: Reflector) {}
  canActivate(ctx: ExecutionContext): boolean {
    const roles = this.reflector.getAllAndOverride<string[]>(ROLES_KEY, [
      ctx.getHandler(),
      ctx.getClass()
    ]);
    if (!roles?.length) return true;

    const req = ctx.switchToHttp().getRequest();
    if (!roles.includes(req.user?.role)) {
      throw new ForbiddenException("Role not allowed");
    }
    return true;
  }
}

@Injectable()
export class PlansGuard implements CanActivate {
  constructor(private reflector: Reflector) {}
  canActivate(ctx: ExecutionContext): boolean {
    const plans = this.reflector.getAllAndOverride<string[]>(PLANS_KEY, [
      ctx.getHandler(),
      ctx.getClass()
    ]);
    if (!plans?.length) return true;

    const req = ctx.switchToHttp().getRequest();
    if (!plans.includes(req.user?.planTier)) {
      throw new ForbiddenException("Plan not allowed");
    }
    return true;
  }
}
```

