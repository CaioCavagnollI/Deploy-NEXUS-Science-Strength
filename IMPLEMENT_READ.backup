## 12.1 Exemplo — Core Profiles + Plans + Usage (trecho)

```sql
create extension if not exists pgcrypto;

create table if not exists public.profiles (
  user_id uuid primary key references auth.users(id) on delete cascade,
  name text,
  role text not null default 'student',
  plan_tier text not null default 'free',
  profession text,
  bio text,
  locale text default 'pt-BR',
  institution_id uuid null,
  affiliate_enabled boolean not null default false,
  is_founder boolean not null default false,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

create table if not exists public.plan_definitions (
  id uuid primary key default gen_random_uuid(),
  plan_tier text unique not null,
  display_name text not null,
  monthly_price_cents int not null default 0,
  annual_price_cents int,
  ai_monthly_messages int,
  workout_prescriptions_monthly int,
  max_students int,
  scanner_enabled boolean not null default false,
  forum_enabled boolean not null default false,
  white_label_enabled boolean not null default false,
  commission_exempt boolean not null default false,
  is_active boolean not null default true,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

create table if not exists public.usage_counters_monthly (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null references auth.users(id) on delete cascade,
  period_ym text not null, -- YYYY-MM
  ai_messages_count int not null default 0,
  workout_generations_count int not null default 0,
  scanner_scans_count int not null default 0,
  created_at timestamptz default now(),
  updated_at timestamptz default now(),
  unique (user_id, period_ym)
);
```

## 12.2 Exemplo — Store / Orders / Entitlements

```sql
create table if not exists public.products (
  id uuid primary key default gen_random_uuid(),
  owner_user_id uuid references auth.users(id),
  slug text unique not null,
  title text not null,
  description text,
  product_type text not null default 'ebook', -- ebook/article/course/program/box
  price_cents int not null,
  compare_at_price_cents int,
  currency text not null default 'BRL',
  visibility_rank int not null default 100, -- founder/pro+/pro/free ordering support
  is_active boolean not null default true,
  is_founder_product boolean not null default false,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

create table if not exists public.product_assets (
  id uuid primary key default gen_random_uuid(),
  product_id uuid not null references public.products(id) on delete cascade,
  storage_path text not null,
  mime_type text,
  file_name text,
  protected_download boolean not null default true,
  created_at timestamptz default now()
);

create table if not exists public.orders (
  id uuid primary key default gen_random_uuid(),
  user_id uuid references auth.users(id),
  status text not null default 'pending', -- pending/paid/failed/refunded
  provider text not null default 'stripe',
  provider_ref text,
  total_cents int not null default 0,
  currency text not null default 'BRL',
  affiliate_click_ref text,
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

create table if not exists public.order_items (
  id uuid primary key default gen_random_uuid(),
  order_id uuid not null references public.orders(id) on delete cascade,
  product_id uuid not null references public.products(id),
  seller_user_id uuid references auth.users(id),
  price_cents int not null,
  commission_cents int not null default 0,
  royalty_cents int not null default 0,
  created_at timestamptz default now()
);

create table if not exists public.entitlements (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null references auth.users(id) on delete cascade,
  product_id uuid not null references public.products(id) on delete cascade,
  order_id uuid references public.orders(id) on delete set null,
  granted_at timestamptz default now(),
  revoked_at timestamptz null,
  unique (user_id, product_id, order_id)
);
```

## 12.3 Exemplo — Affiliates (trecho)

```sql
create table if not exists public.affiliate_profiles (
  id uuid primary key default gen_random_uuid(),
  user_id uuid unique not null references auth.users(id) on delete cascade,
  affiliate_code text unique not null,
  commission_rate_bp int not null default 5000, -- 50%
  is_active boolean not null default true,
  created_at timestamptz default now()
);

create table if not exists public.affiliate_clicks (
  id uuid primary key default gen_random_uuid(),
  affiliate_profile_id uuid not null references public.affiliate_profiles(id) on delete cascade,
  target_type text not null, -- plan|product|service
  target_id text not null,
  click_ref text unique not null,
  created_at timestamptz default now()
);

create table if not exists public.affiliate_conversions (
  id uuid primary key default gen_random_uuid(),
  affiliate_profile_id uuid not null references public.affiliate_profiles(id) on delete cascade,
  order_id uuid null references public.orders(id) on delete set null,
  subscription_id text null,
  gross_amount_cents int not null,
  commission_amount_cents int not null,
  status text not null default 'pending', -- pending|approved|paid|rejected
  created_at timestamptz default now()
);
```

## 12.4 Exemplo — Scanner / Taxonomia / Exercícios (trecho)

```sql
create table if not exists public.taxonomy_version (
  id uuid primary key default gen_random_uuid(),
  version text unique not null,
  notes text,
  created_at timestamptz default now()
);

create table if not exists public.equipment (
  id uuid primary key default gen_random_uuid(),
  equip_id text unique not null, -- canonical id ex: smith_machine
  equipment_name text not null,
  is_active boolean not null default true,
  taxonomy_version_id uuid references public.taxonomy_version(id),
  created_at timestamptz default now()
);

create table if not exists public.equipment_alias (
  id uuid primary key default gen_random_uuid(),
  equipment_id uuid not null references public.equipment(id) on delete cascade,
  alias_label text not null,
  weight numeric not null default 1.0,
  unique (equipment_id, alias_label)
);

create table if not exists public.exercise (
  id uuid primary key default gen_random_uuid(),
  slug text unique not null,
  name text not null,
  exercise_family text,
  is_active boolean not null default true,
  created_at timestamptz default now()
);

create table if not exists public.equipment_exercise (
  id uuid primary key default gen_random_uuid(),
  equipment_id uuid not null references public.equipment(id) on delete cascade,
  exercise_id uuid not null references public.exercise(id) on delete cascade,
  sort_order int not null default 100,
  is_contraindicated boolean not null default false,
  notes text,
  unique (equipment_id, exercise_id)
);

create table if not exists public.exercise_muscle (
  id uuid primary key default gen_random_uuid(),
  exercise_id uuid not null references public.exercise(id) on delete cascade,
  muscle_name text not null,
  role_type text not null, -- prime_mover|synergist|stabilizer
  unique (exercise_id, muscle_name, role_type)
);

create table if not exists public.scanner_log (
  id uuid primary key default gen_random_uuid(),
  scan_id text unique not null,
  user_id uuid references auth.users(id),
  asset_id text,
  status text not null, -- OK|FALLBACK
  equip_id text,
  confidence_score numeric,
  reason text,
  payload_summary jsonb not null default '{}'::jsonb,
  created_at timestamptz default now()
);
```

## 12.5 Exemplo — RAG core (documents/chunks)

```sql
create table if not exists public.documents (
  id uuid primary key default gen_random_uuid(),
  title text not null,
  doc_type text not null,
  source_type text not null default 'primary', -- primary|secondary|tertiary
  author text,
  year int,
  approved boolean not null default false,
  storage_path text,
  created_at timestamptz default now()
);

create table if not exists public.chunks (
  id uuid primary key default gen_random_uuid(),
  document_id uuid not null references public.documents(id) on delete cascade,
  content text not null,
  meta jsonb not null default '{}'::jsonb,
  embedding_id text,
  created_at timestamptz default now()
);

create index if not exists chunks_document_idx on public.chunks(document_id);
```

