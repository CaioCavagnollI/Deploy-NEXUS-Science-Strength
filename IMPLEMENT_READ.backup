# 25) RATE LIMIT REDIS

## 25.1 `apps/api/src/lib/rate-limit/upstash-rate-limit.service.ts`

```ts
import { Injectable } from "@nestjs/common";
import { Redis } from "@upstash/redis";

@Injectable()
export class UpstashRateLimitService {
  private redis: Redis | null = null;

  private getClient() {
    if (this.redis) return this.redis;

    if (process.env.UPSTASH_REDIS_REST_URL && process.env.UPSTASH_REDIS_REST_TOKEN) {
      this.redis = new Redis({
        url: process.env.UPSTASH_REDIS_REST_URL,
        token: process.env.UPSTASH_REDIS_REST_TOKEN
      });
    }
    return this.redis;
  }

  async hit(key: string, windowSeconds: number, maxHits: number) {
    const redis = this.getClient();
    if (!redis) {
      return { allowed: true, count: 1, remaining: maxHits - 1, resetInSec: windowSeconds, bypass: true };
    }

    const now = Math.floor(Date.now() / 1000);
    const bucketKey = `rl:${key}:${Math.floor(now / windowSeconds)}`;
    const count = await redis.incr(bucketKey);
    if (count === 1) await redis.expire(bucketKey, windowSeconds);

    const allowed = count <= maxHits;
    return {
      allowed,
      count,
      remaining: Math.max(0, maxHits - count),
      resetInSec: windowSeconds
    };
  }
}
```

## 25.2 Uso sugerido

* Endpoint `/ai/*`: rate-limit por `userId` + rota
* Endpoint `/scanner/equipment`: rate-limit por `userId`
* Endpoint `/auth/*` públicos: rate-limit por IP

